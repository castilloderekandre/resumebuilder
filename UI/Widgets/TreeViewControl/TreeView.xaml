<UserControl x:Class="UI.Widgets.TreeViewControl.TreeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Widgets.TreeViewControl"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <ListBox x:Name="listBox" Margin="80,41,500,109" Width="220" Height="300"/>
        <Button Content="UP" HorizontalAlignment="Left" Margin="0,41,0,0" VerticalAlignment="Top" Width="75" Click="Up_Button_Click"/>
        <Button Content="DOWN" HorizontalAlignment="Left" Margin="0,66,0,0" VerticalAlignment="Top" Width="75" Click="Down_Button_Click"/>
        <Label x:Name="titleLabel" Content="Title" HorizontalAlignment="Left" Margin="80,10,0,0" VerticalAlignment="Top"/>
        <Button Content="Change Item Collection Source" HorizontalAlignment="Left" Margin="80,346,0,0" VerticalAlignment="Top" Width="220" Visibility="Hidden" Click="Item_Collection_Source_Change_Button_Click"/>

    </Grid>
</UserControl>
